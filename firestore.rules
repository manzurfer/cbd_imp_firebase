rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Listas de tareas ──────────────────────────────────────────────
    match /todoLists/{listId} {

      // Leer: solo miembros
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Crear: cualquier usuario autenticado
      allow create: if request.auth != null
        && request.resource.data.members[request.auth.uid] == 'owner';

      // Actualizar: solo el owner puede modificar miembros/roles
      allow update: if request.auth != null
        && resource.data.members[request.auth.uid] == 'owner';

      // Eliminar: solo el owner
      allow delete: if request.auth != null
        && resource.data.members[request.auth.uid] == 'owner';

      // ── Tareas (subcolección) ─────────────────────────────────────
      match /tasks/{taskId} {

        // Leer: cualquier miembro de la lista padre
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/todoLists/$(listId)).data.members;

        // Crear / Actualizar: owner o editor
        allow create, update: if request.auth != null
          && get(/databases/$(database)/documents/todoLists/$(listId)).data.members[request.auth.uid] in ['owner', 'editor'];

        // Eliminar: owner o editor
        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/todoLists/$(listId)).data.members[request.auth.uid] in ['owner', 'editor'];
      }
    }

    // ── Usuarios (mapeo email ↔ uid) ────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
